# ════════════════════════════════════════════════════════════════
# Backend Alumco - Configuración por Contexto
# NUNCA versiones .env con valores reales — git ignore automático
# ════════════════════════════════════════════════════════════════

# ── Puerto del Servidor ───────────────────────────────────────────
# Local: 3000
# Nube: configurar en plataforma de hosting (ej: Azure, Heroku)
PORT=3000

# ── CORS (Control de Origen) ──────────────────────────────────────
# Local: http://localhost:5173 (frontend Vite local)
# Nube: https://tudominio.com (URL real del frontend en nube)
CORS_ORIGIN=http://localhost:5173

# ── URL para QR en Certificados ──────────────────────────────────
# Esta es la URL que aparecerá en el código QR de los certificados.
# Debe ser la URL pública de tu frontend (ej: https://alumco-capacitacion.cl)
FRONTEND_URL=http://localhost:5173

# ── JWT (Secreto de Autenticación) ───────────────────────────────
# ⚠️ Cambiar a valor largo y aleatorio en TODOS los contextos
# Local: puede ser cualquier string para testing
# Nube: DEBE ser único y seguro (min 32 caracteres, símbolos mixtos)
JWT_SECRET=dev_insecure_local_only_change_in_cloud

# ── Base de Datos PostgreSQL ──────────────────────────────────────
# Local: postgresql://postgres:password@localhost:5432/alumco_dev
# Nube: postgresql://user:password@host:port/database (del proveedor)
# 
# Nota: Usar _dev para local evita confusiones con producción
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alumco_dev

# ── SSL para Conexión a BD ───────────────────────────────────────
# Local: false (conexión local sin SSL)
# Nube: true (recomendado para conexiones remotas)
DB_SSL=false

# ── Seed Automático ─────────────────────────────────────────────────
# Si=true: limpia y re-inserta datos de seed.js en cada arranque
# Usar solo en desarrollo, NUNCA en nube
FORCE_RESEED=false
